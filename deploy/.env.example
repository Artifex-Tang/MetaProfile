# MetaProfile 环境变量说明。复制为 .env 后按实际环境修改。

ENV=dev
LOG_LEVEL=INFO

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Docker 内：postgres:5432   本机直连：localhost:5432
POSTGRES_DSN=postgresql+asyncpg://metaprofile:metaprofile@postgres:5432/metaprofile

# ── Elasticsearch ───────────────────────────────────────────────────────────
ES_HOSTS=["http://elasticsearch:9200"]

# ── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_DSN=redis://redis:6379/0

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

# ── LLM（LiteLLM Proxy）────────────────────────────────────────────────────
LLM_PROXY_BASE_URL=http://litellm:4000
LLM_PROXY_API_KEY=sk-your-master-key
LLM_EXTRACTION_MODEL=qwen2.5-72b-instruct
LLM_GENERATION_MODEL=deepseek-chat
LLM_EMBEDDING_MODEL=bge-large-zh-v1.5

# ── LLM 上游（litellm.yaml 中通过环境变量注入）──────────────────────────────
QWEN_API_KEY=sk-your-dashscope-key
DEEPSEEK_API_KEY=sk-your-deepseek-key

# ── 画像层 REST 地址（分析层用）───────────────────────────────────────────────
PROFILE_API_TECH_BASE_URL=http://profile_tech:8001
PROFILE_API_PROJECT_BASE_URL=http://profile_project:8002
PROFILE_API_ORG_BASE_URL=http://profile_org:8003
PROFILE_API_PERSON_BASE_URL=http://profile_person:8004
PROFILE_API_TIMEOUT_SECONDS=30
